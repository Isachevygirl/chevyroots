# ChevyRoots — Environment Variables
# Copy this file to `.env` and fill in the real values. NEVER commit .env.

# ── Photo pipelines (Python scripts at repo root) ─────────────────────────
# Pexels API — https://www.pexels.com/api/new/
# Used by download_pexels.py and download_pexels_fill.py
PEXELS_API_KEY=

# ── Astro / Netlify runtime ───────────────────────────────────────────────
# Your public canonical site URL (used for OG tags, sitemap, canonical URLs)
SITE_URL=https://chevyroots.com

# ── Email (Phase 1) ───────────────────────────────────────────────────────
# Resend — transactional mail (welcome, approval workflow, contact replies)
# Get a key at https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@chevyroots.com

# Loops.so — newsletter & sequences
# Get a key at https://app.loops.so/settings?page=api
LOOPS_API_KEY=

# ── Database (Phase 1) ────────────────────────────────────────────────────
# Turso — SQLite at the edge, stores affiliate clicks, content ideas,
# build submissions, sessions, etc.
TURSO_DB_URL=
TURSO_AUTH_TOKEN=

# ── Object storage (Phase 4) ──────────────────────────────────────────────
# Cloudflare R2 — raw video uploads from Crystal
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_RAW=chevyroots-raw-uploads
R2_BUCKET_PUBLISHED=chevyroots-published

# ── AI (Phase 2/3/4) ──────────────────────────────────────────────────────
# Anthropic Claude API — article drafting, caption generation, forum synthesis
ANTHROPIC_API_KEY=

# OpenAI — Whisper transcription for voice notes & video audio
OPENAI_API_KEY=

# ── Social publishing (Phase 4) ───────────────────────────────────────────
# YouTube Data API v3
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# Instagram Graph API (Meta)
IG_ACCESS_TOKEN=
IG_BUSINESS_ACCOUNT_ID=

# TikTok Content Posting API
TIKTOK_CLIENT_KEY=
TIKTOK_ACCESS_TOKEN=

# ── Approval workflow ─────────────────────────────────────────────────────
# Shared HMAC secret for signing approve/reject tokens in emails
APPROVAL_JWT_SECRET=

# GitHub Contents API token used to commit approved drafts into the repo
GITHUB_COMMIT_TOKEN=
GITHUB_REPO_OWNER=Isachevygirl
GITHUB_REPO_NAME=chevyroots

# ── Analytics ─────────────────────────────────────────────────────────────
PLAUSIBLE_SITE_ID=chevyroots.com
PLAUSIBLE_API_KEY=

# ── Reddit listener (Phase 3) ─────────────────────────────────────────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=chevyroots-listener/1.0 (contact hello@chevyroots.com)

# ── Optional: HCaptcha/Akismet for form + comment spam ────────────────────
AKISMET_API_KEY=
HCAPTCHA_SITE_KEY=
HCAPTCHA_SECRET=
