---
import BaseLayout from '@layouts/BaseLayout.astro';
import NewsletterCTA from '@components/NewsletterCTA.astro';

// Latest posts (card previews) — preserves the 6 columns from the original
const latestPosts = [
  {
    type: 'First Drive / Review',
    typeClass: 'review',
    title: "I Rented a Camaro for a Day — Here's What Happened",
    preview: "We grabbed a Camaro from the rental lot and spent the day finding out if it lives up to the hype. Spoiler: yes.",
    date: 'April 5, 2026',
    status: 'live',
    anchor: '#camaro-review',
    image: '/photos/camaro/pexels_2797720_camaro.jpeg',
  },
  {
    type: 'Hot Take',
    typeClass: 'hot-take',
    title: 'The Tahoe Is the Most Underrated Chevy — Fight Me',
    preview: "Everyone talks about the Silverado and the Corvette. Nobody gives the Tahoe the respect it deserves. Let me fix that.",
    date: 'Coming Soon',
    status: 'soon',
    image: '/photos/tahoe/pexels_35004984_tahoe.jpeg',
  },
  {
    type: 'Event / Adventure',
    typeClass: 'adventure',
    title: '610 Cruisers: My First Chevy Meet in Virginia',
    preview: "I showed up to a Saturday cruise-in in Stafford, VA and found my people. Here's what went down.",
    date: 'Coming Soon',
    status: 'soon',
    image: '/photos/belair/1955-1957_Chevrolet_Bel_Air_in_the_SunRice_Festival_parade_in_Pine_Ave.jpg',
  },
  {
    type: 'Culture',
    typeClass: 'culture',
    title: "Why Houston Girls Love Chevys (It's in the Water)",
    preview: "Growing up in Houston, Chevys were everywhere — Impalas on swangas, Silverados in every driveway. It wasn't a choice, it was just how it was.",
    date: 'Coming Soon',
    status: 'soon',
    image: '/photos/impala/1964_Chevrolet_Impala_lowrider_5409593989.jpg',
  },
  {
    type: 'Adventure',
    typeClass: 'adventure',
    title: 'Skyline Drive in a Corvette — Our Next Rental Adventure',
    preview: "Shenandoah's most scenic stretch of road. A C8 Corvette. What could go wrong? We're planning it and I'm documenting every turn.",
    date: 'Coming Soon',
    status: 'soon',
    image: '/photos/corvette/Chevrolet_Corvette_C8_IAA_2021_1X7A0156.jpg',
  },
  {
    type: 'Hot Take',
    typeClass: 'hot-take',
    title: "Camaro vs Mustang: Why This Isn't Even a Debate",
    preview: "Every year someone asks me. Every year I give the same answer. Here it is in writing, with receipts, so we can stop having this conversation.",
    date: 'Coming Soon',
    status: 'soon',
    image: '/photos/camaro/pexels_11532597_camaro.jpeg',
  },
];

const playlist = [
  { num: 1, song: "Ridin'", artist: "Chamillionaire ft. Krayzie Bone", vibe: "Houston classic" },
  { num: 2, song: "Chevrolet", artist: "Suga Free", vibe: "West coast" },
  { num: 3, song: "Drive It Like You Stole It", artist: "Squirrel Nut Zippers", vibe: "No notes" },
  { num: 4, song: "Lowrider", artist: "War", vibe: "Impala energy" },
  { num: 5, song: "Cruise", artist: "Florida Georgia Line", vibe: "Truck anthem" },
  { num: 6, song: "Old Chevy", artist: "Matt Stell", vibe: "Country nostalgia" },
  { num: 7, song: "Something to Ride To", artist: "Nipsey Hussle", vibe: "Late night miles" },
];

const schedule = [
  { date: 'Apr 5', name: 'Camaro Rental Review', status: 'Live Now', cls: 'live' },
  { date: 'Apr 11', name: '610 Cruisers Cruise-In — Stafford, VA', status: 'Event', cls: 'event' },
  { date: 'Apr 18', name: 'Corvette C8 Rental + Skyline Drive', status: 'Upcoming', cls: 'upcoming' },
  { date: 'Apr 25', name: 'Tahoe / Silverado Rental Day', status: 'Upcoming', cls: 'upcoming' },
  { date: 'Apr 28–30', name: 'Orioles vs Astros — Camden Yards, Baltimore', status: 'Event', cls: 'event' },
  { date: 'Apr 30', name: "Cruisin' Ocean City", status: 'Event', cls: 'event' },
];

const driving = [
  {
    name: 'Her Chevy Truck',
    role: 'Daily Driver',
    roleClass: 'daily',
    detail: 'The ride-or-die. Does everything, complains about nothing. Gets me where I\'m going and looks good doing it.',
    image: '/photos/crystal/crystal-silverado-zr2-hero.jpg',
  },
  {
    name: 'Corvette C8',
    role: 'Next Rental',
    roleClass: 'next',
    detail: 'Skyline Drive in Shenandoah. Mid-engine. Winding mountain roads. April 18th. I\'m not ready but I\'m doing it.',
    image: '/photos/corvette/Chevrolet_Corvette_C8_IAA_2021_1X7A0156.jpg',
  },
  {
    name: 'Classic C10 — Route 66',
    role: 'Dream Drive',
    roleClass: 'dream',
    detail: 'Square body. Patina. Small-block V8. Windows down on Route 66. This is the dream drive. One day.',
    image: '',
  },
];

const rankings = [
  { name: 'Her Truck', label: 'Daily driver · My truck', quote: '"My ride or die. No debate."', score: '9.0', pct: 90 },
  { name: 'Camaro', label: 'Rental · April 2026', quote: '"Made me feel like a different person."', score: '8.5', pct: 85 },
  { name: 'Next Up: ???', label: 'More coming · Stay tuned', quote: '"The list is growing. Check back."', score: '—', pct: 0, tease: true },
];

const wishlist = [
  {
    name: 'Corvette C8',
    label: 'Next rental target · C8 Mid-Engine',
    quote: '"The most American supercar. I need a whole day with this thing."',
    status: 'ON LIST',
  },
  {
    name: 'Tahoe Z71',
    label: 'Family SUV done right · Off-road trim',
    quote: '"I want to take this thing somewhere with no cell service and zero regrets."',
    status: 'ON LIST',
  },
  {
    name: 'Classic C10',
    label: 'The classic · C10 Stepside or Fleetside',
    quote: '"Square body, patina finish, small-block V8. The dream truck. This is the one I actually want to own."',
    status: 'THE DREAM',
