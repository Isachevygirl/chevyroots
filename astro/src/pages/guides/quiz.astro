---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout
  title="What's Your Chevy? Quiz — Find Your Perfect Chevrolet | ChevyRoots"
  description="Answer five quick questions and we'll point you toward the perfect Chevrolet for your life. Towing, performance, daily driving, budget, off-road — we match you to the right model."
>
  <header class="quiz-header">
    <div class="container container-narrow">
      <p class="section-eyebrow">Buyer's Guide Tool</p>
      <h1 class="quiz-title">What's Your <em>Chevy?</em></h1>
      <span class="gold-line"></span>
      <p class="quiz-lede">
        Five quick questions. Zero fluff. We'll point you toward the Chevrolet that actually fits your life — not the one the dealer wants to sell you.
      </p>
    </div>
  </header>

  <section class="quiz-body">
    <div class="container container-narrow">
      <div class="quiz-coming-soon">
        <h2>Interactive quiz launching soon</h2>
        <p>We're rebuilding this tool as a proper step-by-step interactive quiz. In the meantime, browse the models directly:</p>
        <div class="quiz-categories">
          <a href="/models/trucks/" class="quiz-cat-btn">🚚 Trucks</a>
          <a href="/models/corvette/" class="quiz-cat-btn">🏁 Corvette</a>
          <a href="/models/classics/" class="quiz-cat-btn">⭐ Classics</a>
          <a href="/models/cars/" class="quiz-cat-btn">🚗 Cars</a>
          <a href="/models/suvs/" class="quiz-cat-btn">🚙 SUVs</a>
          <a href="/models/evs/" class="quiz-cat-btn">⚡ EVs</a>
        </div>
        <p><a href="/guides/silverado-buyers-guide/">Start with the Silverado buyer's guide</a> if you're truck-shopping, or <a href="/guides/">browse all guides</a> to find what matches your situation.</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .quiz-header {
    padding: 80px 0 50px;
    background: linear-gradient(180deg, var(--charcoal) 0%, var(--warm-gray) 100%);
  }
  .quiz-title {
    font-family: var(--font-heading);
    font-size: clamp(3rem, 8vw, 6rem);
    font-weight: 900;
    line-height: 0.95;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--off-white);
    margin-top: 0.75rem;
  }
  .quiz-title em { font-style: italic; color: var(--gold); }
  .quiz-lede {
    font-size: 1.1rem;
    color: var(--text-dim);
    line-height: 1.7;
    margin-top: 1.5rem;
  }
  .quiz-body { padding: 60px 0 80px; }
  .quiz-coming-soon {
    background: var(--warm-gray);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 3rem 2rem;
    text-align: center;
  }
  .quiz-coming-soon h2 {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--gold);
    margin-bottom: 1rem;
  }
  .quiz-coming-soon p {
    color: var(--text-dim);
    font-size: 1.05rem;
    line-height: 1.7;
    max-width: 56ch;
    margin: 0 auto 1.5rem;
  }
  .quiz-coming-soon a {
    color: var(--gold);
    text-decoration: underline;
  }
  .quiz-categories {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 0.75rem;
    max-width: 560px;
    margin: 2rem auto;
  }
  .quiz-cat-btn {
    font-family: var(--font-heading);
    font-size: 0.9rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--off-white);
    background: var(--charcoal);
    border: 1px solid var(--mid-gray);
    border-radius: var(--radius);
    padding: 0.85rem 1rem;
    text-decoration: none;
    transition: border-color var(--transition), color var(--transition);
  }
  .quiz-cat-btn:hover {
    border-color: var(--gold);
    color: var(--gold);
  }
</style>
