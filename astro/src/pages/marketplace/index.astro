---
import BaseLayout from '@layouts/BaseLayout.astro';
import NewsletterCTA from '@components/NewsletterCTA.astro';

// Vehicle listings — the 8 featured from the original page
const vehicles = [
  {
    title: '1970 Chevelle SS 454',
    price: '$72,500',
    miles: '47,200',
    location: 'Houston, TX',
    notes: 'Numbers matching',
    condition: 'Excellent',
    conditionClass: 'excellent',
    sellerType: 'Private',
    tags: ['Classic', 'Performance'],
    image: '/photos/chevelle/1970_Chevrolet_Chevelle_SS_-_01.jpg',
  },
  {
    title: '1972 C10 Stepside',
    price: '$28,900',
    miles: '89,400',
    location: 'Nashville, TN',
    notes: 'LS swapped, patina body',
    condition: 'Good',
    conditionClass: 'good',
    sellerType: 'Private',
    tags: ['Classic', 'Truck'],
    image: '/photos/silverado/pexels_3122814_silverado.jpeg',
  },
  {
    title: '2023 Corvette Stingray 3LT',
    price: '$68,900',
    miles: '4,100',
    location: 'Scottsdale, AZ',
    notes: 'Z51 package, Rapid Blue',
    condition: 'Excellent',
    conditionClass: 'excellent',
    sellerType: 'Dealer',
    tags: ['Performance'],
    image: '/photos/corvette/Chevrolet_Corvette_C8_IAA_2021_1X7A0156.jpg',
  },
  {
    title: '1978 K5 Blazer Cheyenne',
    price: '$14,500',
    miles: '132,000',
    location: 'Roanoke, VA',
    notes: 'Runs and drives, rust-free frame',
    condition: 'Fair',
    conditionClass: 'fair',
    sellerType: 'Private',
    tags: ['Classic', 'Truck', 'Project'],
    image: '/photos/colorado/pexels_4595081_colorado.jpeg',
  },
  {
    title: '2024 Silverado 1500 High Country',
    price: '$58,750',
    miles: '1,800',
    location: 'Dallas, TX',
    notes: 'Duramax diesel, fully loaded',
    condition: 'Excellent',
    conditionClass: 'excellent',
    sellerType: 'Dealer',
    tags: ['Truck'],
    image: '/photos/silverado/pexels_10085134_silverado.jpeg',
  },
  {
    title: '2024 Equinox EV 3RS',
    price: '$34,200',
    miles: '2,400',
    location: 'Richmond, VA',
    notes: '319-mi range, Super Cruise',
    condition: 'Excellent',
    conditionClass: 'excellent',
    sellerType: 'Dealer',
    tags: ['EV'],
