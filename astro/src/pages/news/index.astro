---
import BaseLayout from '@layouts/BaseLayout.astro';
import NewsletterCTA from '@components/NewsletterCTA.astro';
import { news } from '@lib/data';

const sortedNews = [...news].sort(
  (a, b) => new Date(b.date).getTime() - new Date(a.date).getTime()
);

// Featured story = most recent
const featured = sortedNews[0];
const rest = sortedNews.slice(1);

const totalCount = sortedNews.length;
const categories = [
  { id: 'all', label: 'All' },
  { id: 'tech', label: 'New Models' },
  { id: 'recall', label: 'Recalls & Safety' },
  { id: 'motorsport', label: 'Racing' },
  { id: 'culture', label: 'Culture' },
  { id: 'ev', label: 'EV News' },
  { id: 'deal', label: 'Deals' },
];

// News sources
const sourcesGroups = [
  {
    title: 'Chevy & GM',
    sources: ['GM Authority', 'Chevrolet Media', 'CorvetteBlogger', 'ChevyHardcore'],
  },
  {
    title: 'Safety & Consumer',
    sources: ['NHTSA', 'Consumer Reports', 'Car and Driver', 'MotorTrend'],
  },
  {
    title: 'Racing & Culture',
    sources: ['NASCAR', 'Barrett-Jackson', 'AAA', 'Hagerty'],
  },
];
---

<BaseLayout
  title="Chevy News — Curated Coverage from Across the Bowtie World | ChevyRoots"
  description={`${totalCount} curated Chevy news stories — new models, recalls, racing headlines, EV updates, deals, and culture. Handpicked, not algorithmically generated. Last updated April 2026.`}
>
  {/* ── HERO ─────────────────────────────────────────── */}
  <section class="news-hero">
    <div class="container">
      <div class="news-hero-grid">
        <div>
          <div class="section-eyebrow">ChevyRoots — Curated Coverage</div>
          <h1 class="news-hero-title">Chevy <em>News</em></h1>
          <span class="gold-line"></span>
          <p class="news-hero-sub">
            The latest from the bowtie world, curated by ChevyRoots. New models, recalls, racing headlines, EV updates, and everything in between — handpicked, not algorithmically generated.
          </p>
          <p class="news-hero-meta">
            Last Updated: April 9, 2026 — Curated by ChevyRoots
          </p>
        </div>
        <div class="news-hero-stat">
          <span class="news-hero-stat-num">{totalCount}</span>
          <span class="news-hero-stat-label">Total Stories</span>
        </div>
      </div>
    </div>
  </section>

  {/* ── FILTER BAR ──────────────────────────────────── */}
  <div class="news-filter-bar">
    <div class="container">
      <div class="filter-bar-inner">
        {categories.map((c, i) => (
          <button
            type="button"
            class={`filter-btn ${i === 0 ? 'active' : ''}`}
            data-filter={c.id}
          >{c.label}</button>
        ))}
      </div>
    </div>
  </div>

  {/* ── SEARCH + CONTENT ────────────────────────────── */}
  <section class="news-main">
    <div class="container">
      <div class="search-bar">
        <span class="search-icon">⌕</span>
        <input
          type="text"
          id="newsSearch"
          placeholder={`Search ${totalCount} stories...`}
          aria-label="Search news"
        />
      </div>

      {featured && (
        <>
          <div class="featured-label">Featured Story</div>
          <a href={featured.url} target="_blank" rel="noopener" class="featured-article">
            <div class="featured-body">
              <div class="featured-meta">
                <span class="featured-source">{featured.source}</span>
                <span class="featured-sep">·</span>
                <span class="featured-date">
                  {new Date(featured.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
                </span>
                <span class={`featured-category cat-${featured.category}`}>{featured.category}</span>
              </div>
              <h2 class="featured-title">{featured.title}</h2>
              <p class="featured-summary">{featured.summary}</p>
              <span class="featured-read">Read original →</span>
            </div>
          </a>
        </>
      )}

      <div class="news-grid" id="newsGrid">
        {rest.map((item) => (
          <a
            href={item.url}
            target="_blank"
            rel="noopener"
            class="news-card"
            data-category={item.category || 'news'}
            data-search={`${item.title} ${item.source} ${item.summary || ''}`.toLowerCase()}
          >
            <div class="news-card-meta">
              <span class="news-card-source">{item.source}</span>
              <span class="news-card-date">
                {new Date(item.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
              </span>
            </div>
            <h3 class="news-card-title">{item.title}</h3>
            <p class="news-card-summary">{item.summary}</p>
            <span class={`news-card-category cat-${item.category}`}>{item.category}</span>
          </a>
        ))}
      </div>

      <div class="no-results" id="noResults" hidden>
        <p>No stories match your search. Try a different term or filter.</p>
      </div>

      {/* ── DISCLAIMER ────────────────────────────────── */}
      <div class="disclaimer-block">
        <p>
          News items are curated from public sources including manufacturer announcements, automotive press, NHTSA filings, and industry outlets. ChevyRoots is not affiliated with General Motors, Chevrolet, or any of their subsidiaries. All stories link to original sources — always read the primary source for full details.
        </p>
        <p>
          Items marked with a warning indicator are based on credible reports but contain unconfirmed or speculative details. Production timelines, specifications, and pricing may change before official announcement.
        </p>
      </div>
    </div>
  </section>

  {/* ── NEWS SOURCES WE WATCH ────────────────────────── */}
  <section class="sources-section">
    <div class="container">
      <div class="sources-inner">
        <div class="sources-heading">
          <div class="section-eyebrow">Where We Look</div>
          <h2 class="sources-title">News Sources<br />We Watch</h2>
          <span class="gold-line"></span>
          <p class="sources-desc">
            We read it all so you don't have to. These are the outlets we monitor to bring you curated Chevy coverage.
          </p>
          <div class="sources-tagline">Curated, not aggregated.</div>
        </div>
        <div class="sources-groups">
          {sourcesGroups.map((g) => (
            <div>
              <div class="source-group-title">{g.title}</div>
              <ul class="source-list">
                {g.sources.map((s) => <li>{s}</li>)}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  {/* ── SUBMIT A TIP ─────────────────────────────────── */}
  <section class="tip-section">
    <div class="container container-narrow">
      <div class="tip-inner">
        <div>
          <div class="tip-icon">🗝</div>
          <div class="section-eyebrow">Got a lead?</div>
          <h2 class="tip-title">Submit a Tip</h2>
          <p class="tip-desc">
            Got Chevy news we should cover? Spotted a recall that hasn't hit the radar yet? Know about an upcoming model or dealer event? Send it our way — we read every tip.
          </p>
          <div class="tip-email">news@chevyroots.com</div>
        </div>
        <a href="mailto:news@chevyroots.com" class="btn btn-outline">Send a Tip →</a>
      </div>
    </div>
  </section>

  <NewsletterCTA
    source="news-index"
    heading="Get the Weekly News Roundup"
    subheading="Every week, the biggest Chevy headlines curated into one clean email. No spam, no fluff — just the news that matters to Chevy people."
  />
</BaseLayout>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const searchInput = document.getElementById('newsSearch') as HTMLInputElement;
  const cards = document.querySelectorAll<HTMLAnchorElement>('.news-card');
  const noResults = document.getElementById('noResults') as HTMLDivElement;
  const newsGrid = document.getElementById('newsGrid') as HTMLDivElement;

  let currentFilter = 'all';

  function applyFilters() {
    const q = searchInput.value.toLowerCase().trim();
    let visible = 0;
    cards.forEach((card) => {
      const cat = card.dataset.category || 'news';
      const search = card.dataset.search || '';
      const matchCat = currentFilter === 'all' || cat === currentFilter;
      const matchQ = !q || search.includes(q);
      if (matchCat && matchQ) {
        card.style.display = '';
        visible++;
      } else {
        card.style.display = 'none';
      }
    });
    noResults.hidden = visible > 0;
    newsGrid.style.display = visible > 0 ? '' : 'none';
  }

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      filterBtns.forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');
      currentFilter = btn.dataset.filter || 'all';
      applyFilters();
    });
  });
  searchInput?.addEventListener('input', applyFilters);
</script>

<style>
  /* ── HERO ─────────────────────────────────────────── */
  .news-hero {
    padding: 80px 0 50px;
    background: linear-gradient(180deg, var(--charcoal) 0%, var(--warm-gray) 100%);
  }
  .news-hero-grid {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 3rem;
    align-items: center;
  }
  .news-hero-title {
    font-family: var(--font-heading);
    font-size: clamp(3rem, 7vw, 5.5rem);
    font-weight: 900;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--off-white);
    margin-top: 0.75rem;
  }
  .news-hero-title em { font-style: italic; color: var(--gold); }
  .news-hero-sub {
    font-size: 1.1rem;
    color: var(--text-dim);
    line-height: 1.7;
    max-width: 60ch;
    margin-top: 1.5rem;
  }
  .news-hero-meta {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--light-gray);
    margin-top: 1.25rem;
  }
  .news-hero-stat {
    text-align: center;
    padding: 2rem;
    background: var(--warm-gray);
    border: 1px solid var(--border);
    border-left: 3px solid var(--gold);
    border-radius: var(--radius-lg);
  }
  .news-hero-stat-num {
    display: block;
    font-family: var(--font-heading);
    font-size: 4rem;
    font-weight: 900;
    color: var(--gold);
    line-height: 1;
  }
  .news-hero-stat-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--light-gray);
    margin-top: 0.75rem;
  }

  /* ── FILTER BAR ──────────────────────────────────── */
  .news-filter-bar {
    background: var(--charcoal);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 1rem 0;
    position: sticky;
    top: var(--nav-height);
    z-index: 10;
  }
  .filter-bar-inner {
    display: flex;
    gap: 0.5rem;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .filter-bar-inner::-webkit-scrollbar { display: none; }
  .filter-btn {
    font-family: var(--font-heading);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.6rem 1.1rem;
    background: var(--warm-gray);
    color: var(--light-gray);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    cursor: pointer;
    white-space: nowrap;
    transition: all var(--transition);
  }
  .filter-btn:hover { color: var(--gold); border-color: var(--gold); }
  .filter-btn.active {
    background: var(--gold);
    color: var(--charcoal);
    border-color: var(--gold);
  }

  /* ── MAIN ─────────────────────────────────────────── */
  .news-main {
    padding: var(--section-pad) 0;
  }
  .search-bar {
    position: relative;
    margin-bottom: 2rem;
    max-width: 600px;
  }
  .search-bar input {
    width: 100%;
    padding: 0.85rem 1rem 0.85rem 3rem;
    background: var(--warm-gray);
    border: 1px solid var(--mid-gray);
    color: var(--off-white);
    border-radius: var(--radius);
    font-family: var(--font-body);
    font-size: 0.95rem;
  }
  .search-bar input:focus { outline: none; border-color: var(--gold); }
  .search-icon {
    position: absolute;
    left: 1.25rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--gold);
    font-size: 1.2rem;
  }

  .featured-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1rem;
  }
  .featured-article {
    display: block;
    padding: 2rem;
    background: var(--warm-gray);
    border: 2px solid var(--gold);
    border-radius: var(--radius-lg);
    text-decoration: none;
    margin-bottom: 3rem;
    transition: transform var(--transition);
  }
  .featured-article:hover { transform: translateY(-3px); }
  .featured-meta {
    display: flex;
    gap: 0.6rem;
    align-items: center;
    flex-wrap: wrap;
    margin-bottom: 1rem;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .featured-source { color: var(--gold); font-weight: 700; }
  .featured-sep { color: var(--light-gray); }
  .featured-date { color: var(--light-gray); }
  .featured-title {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--off-white);
    line-height: 1.15;
    margin-bottom: 1rem;
  }
  .featured-summary {
    font-size: 1rem;
    color: var(--text-dim);
    line-height: 1.65;
    margin-bottom: 1rem;
    max-width: 72ch;
  }
  .featured-read {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gold);
  }

  .news-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.25rem;
    margin-bottom: 3rem;
  }
  .news-card {
    padding: 1.5rem;
    background: var(--warm-gray);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: border-color var(--transition), transform var(--transition);
  }
  .news-card:hover {
    border-color: var(--gold);
    transform: translateY(-3px);
  }
  .news-card-meta {
    display: flex;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .news-card-source { color: var(--gold); }
  .news-card-date { color: var(--text-mute); }
  .news-card-title {
    font-family: var(--font-heading);
    font-size: 1.05rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.01em;
    color: var(--off-white);
    line-height: 1.25;
  }
  .news-card-summary {
    font-size: 0.82rem;
    color: var(--text-dim);
    line-height: 1.55;
    flex: 1;
  }
  .news-card-category {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.2rem 0.5rem;
    border-radius: 3px;
    align-self: flex-start;
  }
  .cat-tech { background: rgba(94, 183, 240, 0.15); color: #5eb7f0; }
  .cat-recall { background: rgba(224, 108, 90, 0.15); color: #e06c5a; }
  .cat-motorsport { background: rgba(229, 115, 74, 0.15); color: #f1a663; }
  .cat-culture { background: rgba(196, 160, 53, 0.15); color: var(--gold); }
  .cat-ev { background: rgba(122, 220, 159, 0.15); color: #7adc9f; }
  .cat-deal { background: rgba(94, 183, 240, 0.15); color: #5eb7f0; }
  .cat-news { background: var(--charcoal); color: var(--light-gray); }

  .no-results {
    text-align: center;
    padding: 3rem;
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .disclaimer-block {
    margin-top: 2rem;
    padding: 1.5rem;
    background: var(--warm-gray);
    border-left: 3px solid var(--gold);
    border-radius: var(--radius);
  }
  .disclaimer-block p {
    font-size: 0.82rem;
    color: var(--text-dim);
    line-height: 1.65;
    margin-bottom: 0.75rem;
  }
  .disclaimer-block p:last-child { margin-bottom: 0; }

  /* ── SOURCES ─────────────────────────────────────── */
  .sources-section {
    padding: var(--section-pad) 0;
    background: var(--warm-gray);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .sources-inner {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 3rem;
    align-items: start;
  }
  .sources-title {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 900;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--off-white);
    margin: 0.75rem 0 1rem;
  }
  .sources-desc {
    color: var(--text-dim);
    font-size: 0.9rem;
    line-height: 1.65;
    margin-top: 0.75rem;
    max-width: 28ch;
  }
  .sources-tagline {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--gold);
    margin-top: 1.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--border);
  }
  .sources-groups {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1.5rem;
  }
  .source-group-title {
    font-family: var(--font-heading);
    font-size: 0.85rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(196, 160, 53, 0.3);
  }
  .source-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .source-list li {
    padding: 0.35rem 0;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-dim);
    letter-spacing: 0.02em;
  }

  /* ── TIP SECTION ─────────────────────────────────── */
  .tip-section {
    padding: var(--section-pad) 0;
  }
  .tip-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
    padding: 2.5rem;
    background: var(--warm-gray);
    border: 1px solid var(--border);
    border-left: 3px solid var(--gold);
    border-radius: var(--radius-lg);
    flex-wrap: wrap;
  }
  .tip-icon {
    font-size: 2rem;
    margin-bottom: 0.75rem;
  }
  .tip-title {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    font-weight: 900;
    text-transform: uppercase;
    color: var(--off-white);
    margin: 0.5rem 0 0.75rem;
  }
  .tip-desc {
    font-size: 0.95rem;
    color: var(--text-dim);
    line-height: 1.65;
    max-width: 56ch;
    margin-bottom: 1rem;
  }
  .tip-email {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    color: var(--gold);
    letter-spacing: 0.04em;
  }

  @media (max-width: 900px) {
    .news-hero-grid, .sources-inner { grid-template-columns: 1fr; }
  }
</style>
