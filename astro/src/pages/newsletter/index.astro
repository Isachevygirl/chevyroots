---
import BaseLayout from '@layouts/BaseLayout.astro';

const benefits = [
  {
    icon: '🏆',
    title: 'Build of the Week',
    desc: 'One featured community build — full spec breakdown, owner story, and the photo that makes you jealous. Trucks, muscle, restomods, and everything in between.',
  },
  {
    icon: '📰',
    title: 'Chevy News Roundup',
    desc: 'The Chevy headlines that actually matter — no rehashed press releases, no hype. New model updates, recall notices worth knowing about, and factory announcements.',
  },
  {
    icon: '📅',
    title: 'Event Calendar Highlights',
    desc: 'Car shows, swap meets, cruise-ins, and track days across the country. Curated picks — not a raw list of everything happening in 47 states.',
  },
  {
    icon: '🏷',
    title: 'Exclusive Partner Deals',
    desc: 'When founding partners come on board, subscribers get first access to special pricing, early product drops, and giveaways. Coming soon.',
  },
  {
    icon: '⭐',
    title: "Crystal's Picks",
    desc: "One tool, part, resource, or read I've come across that week that's actually worth your time. No sponsored picks. Just stuff I'd tell a friend.",
  },
];
---

<BaseLayout
  title="The Weekly Wrench — Free Chevy Newsletter Every Thursday | ChevyRoots"
  description="Subscribe to The Weekly Wrench — a free weekly Chevy newsletter. Build of the Week, Chevy news roundup, event highlights, and Crystal's picks. Every Thursday. No spam."
>
  {/* ── HERO ──────────────────────────────────────────── */}
  <section class="nl-hero">
    <div class="container">
      <div class="hero-wrench-icon">🔧</div>
      <p class="section-eyebrow">Free Weekly Newsletter</p>
      <h1 class="nl-hero-title">The Weekly<br /><span class="gold">Wrench</span></h1>
      <span class="gold-line"></span>
      <p class="nl-hero-sub">New builds, deep dives, and event coverage — every Thursday.</p>
      <div class="hero-meta">
        <div class="hero-meta-item"><span class="dot"></span>Every Thursday</div>
        <div class="hero-meta-item"><span class="dot"></span>100% Free</div>
        <div class="hero-meta-item"><span class="dot"></span>No spam, ever</div>
        <div class="hero-meta-item"><span class="dot"></span>Unsubscribe anytime</div>
      </div>
    </div>
  </section>

  {/* ── SIGNUP + BENEFITS ────────────────────────────── */}
  <section class="signup-section">
    <div class="container">
      <div class="signup-grid">
        <div>
          <p class="section-eyebrow">What you get</p>
          <h2 class="benefits-title">
            One Email.<br />Every Thursday.<br /><span class="gold">All Signal.</span>
          </h2>
          <span class="gold-line"></span>
          <div class="benefits-list">
            {benefits.map((b) => (
              <div class="benefit-item">
                <span class="benefit-icon">{b.icon}</span>
                <div>
                  <div class="benefit-title">{b.title}</div>
                  <div class="benefit-desc">{b.desc}</div>
                </div>
              </div>
            ))}
          </div>
        </div>
        <div class="signup-right">
          <div class="signup-box">
            <p class="signup-label">Subscribe free</p>
            <h2 class="signup-title">Join the<br /><span class="gold">Weekly Wrench</span></h2>
            <p class="signup-sub">
              Real Chevy content, one email a week. No fluff, no affiliate noise, no spam.
            </p>
            <div class="signup-count">
              <span class="dot"></span>
              Join <strong>10,000+</strong> other Chevy enthusiasts
            </div>
            <form
              class="nl-form"
              data-newsletter-form
              data-source="newsletter-hero"
              action="/api/subscribe"
              method="POST"
              novalidate
            >
              <label class="visually-hidden" for="nl-email-top">Email address</label>
              <input
                type="email"
                id="nl-email-top"
                name="email"
                required
                autocomplete="email"
                placeholder="you@example.com"
              />
              <input type="hidden" name="source" value="newsletter-hero" />
              <button type="submit" class="btn btn-gold">Subscribe — It's Free</button>
            </form>
            <p class="signup-disclaimer">
              No spam, no fluff. Unsubscribe anytime. We don't sell or share your email.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ── SAMPLE ISSUE ─────────────────────────────────── */}
  <section class="sample-section">
    <div class="container container-narrow">
      <div class="sample-header">
        <p class="section-eyebrow">Sample issue</p>
        <h2 class="sample-title">What a Real Issue Looks Like</h2>
        <span class="gold-line"></span>
        <p class="sample-intro">
          Here's an example of a typical Thursday send. This is the actual format, not a marketing mock-up.
        </p>
      </div>

      <div class="email-preview">
        <div class="email-chrome">
          <div class="chrome-dot chrome-red"></div>
          <div class="chrome-dot chrome-yellow"></div>
          <div class="chrome-dot chrome-green"></div>
          <span class="chrome-subject">The Weekly Wrench — Issue #12 — April 3, 2026</span>
        </div>

        <div class="email-header">
          <div class="email-logo">Chevy<em>Roots</em></div>
          <div class="email-issue-line">The Weekly Wrench — Issue 12 — April 3, 2026</div>
        </div>

        <div class="email-headline-bar">
          <h3>Big-Block Thursday</h3>
          <p>1970 Chevelle SS feature · 2027 Silverado news · Spring shows · Crystal's pick</p>
        </div>

        <div class="email-body">
          <div class="email-section-label">Build of the Week</div>
          <div class="email-build-feature">
            <div
              class="email-build-thumb"
              style="background-image: url('/photos/chevelle/1970_Chevrolet_Chevelle_SS_-_01.jpg');"
            ></div>
            <div class="email-build-info">
              <h4>1970 Chevelle SS 454 — "Green Machine"</h4>
              <p>
                Marcus T. spent four years on a frame-off restomod, swapped in a 525-whp big block, and kept the Fathom Green that makes it impossible to ignore. Full spec rundown inside.
              </p>
              <a href="/builds/">Read the full build →</a>
            </div>
          </div>

          <div class="email-section-label">Chevy News This Week</div>
          <div class="email-news-items">
            <div class="email-news-item">
              <span class="bullet">▸</span>
              <span><strong>2027 Silverado HD spy shots surface</strong> — early prototypes show revised front end and updated infotainment. Debut expected at SEMA.</span>
            </div>
            <div class="email-news-item">
              <span class="bullet">▸</span>
              <span><strong>C8 Corvette E-Ray production numbers</strong> — GM confirms limited 2026 allocation; dealers already reporting waitlists.</span>
            </div>
            <div class="email-news-item">
              <span class="bullet">▸</span>
              <span><strong>Equinox EV range update</strong> — over-the-air software pushed this week bumps estimated range by 14 miles on the 2LT trim.</span>
            </div>
          </div>

          <div class="email-section-label">Events Worth Your Weekend</div>
          <div class="email-events">
            <div class="email-event-row">
              <span class="email-event-date">Apr 12</span>
              <span>Bloomington Gold Corvette Show — Indianapolis Motor Speedway, IN</span>
            </div>
            <div class="email-event-row">
              <span class="email-event-date">Apr 19</span>
              <span>Spring Carlisle Swap Meet — Carlisle, PA (Chevy section in Lot J)</span>
            </div>
            <div class="email-event-row">
              <span class="email-event-date">Apr 26</span>
              <span>Texas Classics at Kyle Field — College Station, TX</span>
            </div>
          </div>

          <div class="email-section-label">Crystal's Picks This Week</div>
          <div class="email-picks">
            <div class="email-pick-item">
              <span class="pick-icon">🔧</span>
              <span>
                <strong>Tool:</strong> Gearwrench 80559 flex-head ratcheting wrench — finally bought one after borrowing a friend's for years. Worth every dollar.
              </span>
            </div>
            <div class="email-pick-item">
              <span class="pick-icon">📚</span>
              <span>
                <strong>Read:</strong> <em>Muscle Car Review</em>'s 2026 buyer guide — surprisingly honest about which classics are money pits right now.
              </span>
            </div>
            <div class="email-pick-item">
              <span class="pick-icon">📹</span>
              <span>
                <strong>Watch:</strong> Matt Farah's latest street drive of the C8 Z06 convertible. If you have 18 minutes, just watch it.
              </span>
            </div>
          </div>
        </div>

        <div class="email-footer">
          <p>
            You're receiving this because you subscribed at chevyroots.com<br />
            <a href="#">Unsubscribe</a> — <a href="#">View in browser</a> — <a href="#">Manage preferences</a><br />
            ChevyRoots is an independent resource. Not affiliated with General Motors or Chevrolet.
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* ── BOTTOM CTA ──────────────────────────────────── */}
  <section class="bottom-cta">
    <div class="container container-narrow">
      <p class="section-eyebrow">Ready to subscribe?</p>
      <h2 class="cta-title">
        First issue hits your inbox <span class="gold">Thursday</span>
      </h2>
      <p class="cta-sub">Join the list. One email a week. Cancel whenever. No fluff, no junk.</p>
      <form
        class="nl-form nl-form-bottom"
        data-newsletter-form
        data-source="newsletter-bottom"
        action="/api/subscribe"
        method="POST"
        novalidate
      >
        <label class="visually-hidden" for="nl-email-bottom">Email address</label>
        <input
          type="email"
          id="nl-email-bottom"
          name="email"
          required
          autocomplete="email"
          placeholder="your@email.com"
        />
        <input type="hidden" name="source" value="newsletter-bottom" />
        <button type="submit" class="btn btn-gold">Subscribe</button>
      </form>
      <p class="cta-disclaimer">No spam, no fluff. Unsubscribe anytime.</p>
    </div>
  </section>
</BaseLayout>

<script>
  // Wire up the two newsletter forms the same way the NewsletterCTA component does
  const forms = document.querySelectorAll<HTMLFormElement>('[data-newsletter-form]');
  forms.forEach((form) => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const emailInput = form.querySelector<HTMLInputElement>('input[type=email]');
      if (!emailInput || !emailInput.value.includes('@')) return;
      try {
        const res = await fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            email: emailInput.value,
            source: form.dataset.source || 'newsletter',
          }),
        });
        if (res.ok) {
          form.innerHTML = '<p style="color:var(--gold);font-family:var(--font-heading);font-size:1.1rem;text-transform:uppercase;letter-spacing:0.04em;">✓ Thanks — check your inbox to confirm.</p>';
        }
      } catch (err) {
        console.error('Subscribe failed:', err);
      }
    });
  });
</script>

<style>
  /* ── HERO ──────────────────────────────────────────── */
  .nl-hero {
